# Telegram (required)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# RackNerd / VPS — long polling (no HTTPS required on the VPS)
STIX_ALLOW_POLLING=1
STIX_TRANSPORT=polling
STIX_CLEAR_WEBHOOK_BEFORE_POLL=1

# Optional: webhook mode if you put nginx + TLS in front
# STIX_TRANSPORT=webhook
# STIX_TELEGRAM_WEBHOOK_URL=https://your-domain.example/stix-webhook
# PORT=8080

# Optional APIs
OPENAI_API_KEY=
GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Access control (operator commands)
# PUPBOT_OWNER_IDS=123456789
